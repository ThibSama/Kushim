DATABASE_URL=postgresql://kushim:kushim_secret_dev@localhost:5432/kushim
RUST_LOG=info
MARKET_DATA_HOST=0.0.0.0
MARKET_DATA_PORT=8082
MARKET_DATA_MODE=idle
MARKET_DATA_JOB=noop
MARKET_DATA_PROVIDER=mock
MARKET_DATA_RUN_INTERVAL_SECONDS=300
MARKET_DATA_SYMBOL_ALLOWLIST=AAPL,MSFT,NVDA
# Optional provider request symbol mapping for canonical Kushim symbols.
# Example for Finnhub crypto current quotes:
# MARKET_DATA_PROVIDER_SYMBOL_MAP=BTC=BINANCE:BTCUSDT
MARKET_DATA_HTTP_TIMEOUT_SECONDS=10
MARKET_DATA_PROVIDER_DELAY_MS=1100
FINNHUB_API_KEY=change_me
# FINNHUB_BASE_URL=https://finnhub.io/api/v1
# MARKET_DATA_HISTORY_DATE_FROM=2026-01-01
# MARKET_DATA_HISTORY_DATE_TO=2026-01-31
APP_ENV=development
