KUSHIM_API_HOST=0.0.0.0
KUSHIM_API_PORT=8080
APP_ENV=development
RUST_LOG=info
DATABASE_URL=postgresql://kushim:kushim_secret_dev@localhost:5432/kushim
REDIS_URL=redis://127.0.0.1:6379/0
AUTH_JWT_SECRET=dev_only_change_me_minimum_32_chars
JWT_ISSUER=kushim-auth
# Direct-dev browser origin. In Docker, docker-compose.yml overrides this with
# the canonical nginx origin (the app), plus the direct-dev origin:
#   http://app.kushim.localhost,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
