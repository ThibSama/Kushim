AUTH_SERVICE_HOST=0.0.0.0
AUTH_SERVICE_PORT=3002
APP_ENV=development
DATABASE_URL=postgresql://kushim:kushim_secret_dev@localhost:5432/kushim
REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_ENABLED=false
AUTH_JWT_SECRET=dev_only_change_me_minimum_32_chars
JWT_ISSUER=kushim-auth
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
# Direct-dev browser origins. In Docker, docker-compose.yml overrides this with
# the canonical nginx origins (auth frontend + app, plus direct-dev origins):
#   http://auth.kushim.localhost,http://app.kushim.localhost,http://localhost:3001,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173
RUST_LOG=info
