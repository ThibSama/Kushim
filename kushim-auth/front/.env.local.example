# Direct local development (services run on host ports).
# In Docker, docker-compose.yml overrides these with canonical nginx URLs:
#   NEXT_PUBLIC_APP_URL=http://app.kushim.localhost
#   NEXT_PUBLIC_WEBSITE_URL=http://kushim.localhost
#   NEXT_PUBLIC_AUTH_API_URL=http://auth-api.kushim.localhost
NEXT_PUBLIC_APP_URL=http://localhost:5173
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3002
