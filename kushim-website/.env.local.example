# Direct local development (services run on host ports).
# In Docker, docker-compose.yml overrides this with the canonical nginx URL:
#   NEXT_PUBLIC_AUTH_URL=http://auth.kushim.localhost
NEXT_PUBLIC_AUTH_URL=http://localhost:3001

# Canonical public origin used by metadata, robots.txt, and sitemap.xml.
# Defaults to http://localhost:3000 when omitted in local development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
