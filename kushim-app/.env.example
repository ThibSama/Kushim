# Direct local development (services run on host ports).
# In Docker, docker-compose.yml overrides these with canonical nginx URLs:
#   VITE_AUTH_URL=http://auth.kushim.localhost
#   VITE_AUTH_API_URL=http://auth-api.kushim.localhost
#   VITE_API_URL=http://api.kushim.localhost
VITE_AUTH_URL=http://localhost:3001
VITE_AUTH_API_URL=http://localhost:3002
VITE_API_URL=http://localhost:8080
