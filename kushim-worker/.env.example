DATABASE_URL=postgresql://kushim:kushim_secret_dev@localhost:5432/kushim
APP_ENV=development
RUST_LOG=info
WORKER_NAME=kushim-worker
# Automatic portfolio refresh consumer (P0). For one-off maintenance jobs use
# WORKER_MODE=once with a specific WORKER_JOB instead.
WORKER_MODE=loop
WORKER_JOB=process_portfolio_refresh_requests
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_TARGET_PORTFOLIO_ID=
WORKER_SNAPSHOT_DATE=
WORKER_BACKFILL_DATE_FROM=
WORKER_BACKFILL_DATE_TO=
# Refresh consumer tunables (conservative MVP defaults).
WORKER_REFRESH_BATCH_SIZE=10
WORKER_REFRESH_MAX_ATTEMPTS=5
WORKER_REFRESH_RETRY_DELAY_SECONDS=30
WORKER_REFRESH_LOCK_TIMEOUT_SECONDS=300
REDIS_URL=redis://127.0.0.1:6379/0
WORKER_HEALTH_HOST=127.0.0.1
WORKER_HEALTH_PORT=8081
